{
  "name": "server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && mkdir -p dist/data && cp src/data/places.json src/data/connections.json src/data/lexicon.json dist/data/",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "seed:context": "tsx src/seed/seedBookContext.ts",
    "seed:places": "tsx src/seed/seedPlaces.ts",
    "seed:plans": "tsx src/seed/seedPlans.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^12.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}

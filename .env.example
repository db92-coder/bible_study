# ─────────────────────────── Server ───────────────────────────
PORT=4000

# Firebase Admin SDK service account (Project settings → Service accounts → Generate new private key)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private_key value including the \n escapes, wrapped in quotes:
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# Supabase (Project settings → API). Service-role key is server-only — never expose to the client.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# API.Bible key (scripture.api.bible). Optional in dev — falls back to bible-api.com (WEB/KJV).
API_BIBLE_KEY=

# Anthropic API key for the study chatbot (server-only).
ANTHROPIC_API_KEY=

# ─────────────────────── Client (Vite) ────────────────────────
# Firebase web app config (Project settings → General → Your apps → Web app)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
